    "url": "git+https://github.com/viniciusftasso/zpl-canvas.git"
  },
  "bugs": {
    "url": "https://github.com/viniciusftasso/zpl-canvas/issues"
  },
  "homepage": "https://github.com/viniciusftasso/zpl-canvas#readme",
  "license": "MIT",
  "dependencies": {
    "bwip-js": "^4.11.1"
  },
  "peerDependencies": {
    "@napi-rs/canvas": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@napi-rs/canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
