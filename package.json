{
  "name": "zpl-canvas",
  "version": "0.0.1",
  "description": "Render ZPL labels to Canvas and PNG in native JavaScript.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "check": "node --check src/*.js",
    "demo:dev": "vite --host 127.0.0.1",
    "demo:build": "vite build"
  },
  "keywords": [
    "zpl",
    "zplii",
